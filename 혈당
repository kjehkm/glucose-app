// ============ WEB NFC API ============

async function startNFCRead() {
  if (!('NDEFReader' in window)) {
    showToast('⚠️ 이 기기는 NFC를 지원하지 않습니다');
    setTimeout(() => showInputPhase(), 1500);
    return;
  }

  document.getElementById('welcomePhase').classList.add('hidden');
  document.getElementById('nfcReadingPhase').classList.remove('hidden');

  nfcAbortController = new AbortController();

  try {
    const ndef = new NDEFReader();
    await ndef.scan({ signal: nfcAbortController.signal });

    ndef.onreading = (event) => {
      handleNFCReading(event);
    };

    ndef.onerror = () => {
      showToast('❌ NFC 읽기 실패');
      cancelNFCRead();
    };
  } catch (error) {
    if (error.name === 'AbortError') {
      return;
    }
    // NFC 권한 거부 또는 기기 미지원 시 수동 입력으로 폴백
    showToast('⚠️ NFC 접근 불가 → 수동 입력으로 변경');
    setTimeout(() => {
      cancelNFCRead();
      showInputPhase();
    }, 1500);
  }
}

function handleNFCReading(event) {
  const decoder = new TextDecoder();
  let glucoseValue = null;

  for (const record of event.message.records) {
    if (record.recordType === 'text') {
      const text = decoder.decode(record.data);
      const match = text.match(/(\d+)/);
      if (match) {
        glucoseValue = parseInt(match[1]);
        break;
      }
    } else if (record.recordType === 'url') {
      const url = decoder.decode(record.data).substring(1);
      const match = url.match(/glucose[=:](\d+)/i);
      if (match) {
        glucoseValue = parseInt(match[1]);
        break;
      }
    }
  }

  if (glucoseValue && glucoseValue >= 40 && glucoseValue <= 300) {
    nfcAbortController.abort();
    document.getElementById('nfcReadingPhase').classList.add('hidden');
    document.getElementById('nfcBefore').value = glucoseValue;
    document.getElementById('nfcConfirmPhase').classList.remove('hidden');
    showToast('✓ NFC 읽음: ' + glucoseValue);
  } else {
    showToast('⚠️ 유효한 혈당 데이터가 없습니다');
  }
}

function cancelNFCRead() {
  if (nfcAbortController) {
    nfcAbortController.abort();
  }
  document.getElementById('nfcReadingPhase').classList.add('hidden');
  document.getElementById('welcomePhase').classList.remove('hidden');
}

