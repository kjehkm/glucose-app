// 그래프 그리기
function drawGlucoseChart() {
  const canvas = document.getElementById('glucoseChart');
  if (!canvas) return;
  
  const container = canvas.parentElement;
  const width = container.offsetWidth || 300;
  const height = container.offsetHeight || 200;
  canvas.width = width;
  canvas.height = height;
  
  const ctx = canvas.getContext('2d');
  
  const data = allRecords.slice(0, 10).reverse();
  
  if (data.length === 0) {
    ctx.fillStyle = '#cbd5e1';
    ctx.font = '12px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('데이터 없음', width / 2, height / 2);
    return;
  }
  
  const padding = 30;
  const chartWidth = width - padding * 2;
  const chartHeight = height - padding * 2;
  const minGlucose = 60;
  const maxGlucose = 200;
  const range = maxGlucose - minGlucose;
  
  // 그리드
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = padding + (chartHeight / 4) * i;
    ctx.beginPath();
    ctx.moveTo(padding, y);
    ctx.lineTo(width - padding, y);
    ctx.stroke();
  }
  
  // 축
  ctx.strokeStyle = 'rgba(255,255,255,0.2)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(padding, height - padding);
  ctx.lineTo(width - padding, height - padding);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(padding, padding);
  ctx.lineTo(padding, height - padding);
  ctx.stroke();
  
  // Y축 라벨
  ctx.fillStyle = '#cbd5e1';
  ctx.font = '10px sans-serif';
  ctx.textAlign = 'right';
  for (let i = 0; i <= 4; i++) {
    const value = minGlucose + (range / 4) * i;
    const y = height - padding - (chartHeight / 4) * i;
    ctx.fillText(Math.round(value), padding - 8, y + 3);
  }
  
  // 목표선 (140)
  const targetY = height - padding - ((140 - minGlucose) / range) * chartHeight;
  ctx.strokeStyle = '#22c55e';
  ctx.lineWidth = 2;
  ctx.setLineDash([5, 5]);
  ctx.beginPath();
  ctx.moveTo(padding, targetY);
  ctx.lineTo(width - padding, targetY);
  ctx.stroke();
  ctx.setLineDash([]);
  
  const pointSpacing = data.length > 1 ? chartWidth / (data.length - 1) : chartWidth / 2;
  
  // 식전 라인
  ctx.strokeStyle = '#60a5fa';
  ctx.lineWidth = 2;
  ctx.beginPath();
  data.forEach((rec, i) => {
    const x = padding + i * pointSpacing;
    const y = height - padding - ((rec.glucose_before - minGlucose) / range) * chartHeight;
    if (i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  });
  ctx.stroke();
  
  // 식후 라인
  ctx.strokeStyle = '#ef4444';
  ctx.lineWidth = 2;
  ctx.beginPath();
  data.forEach((rec, i) => {
    const x = padding + i * pointSpacing;
    const y = height - padding - ((rec.glucose_after - minGlucose) / range) * chartHeight;
    if (i === 0) ctx.moveTo(x, y);
    else ctx.lineTo(x, y);
  });
  ctx.stroke();
  
  // 점 표시
  data.forEach((rec, i) => {
    const x = padding + i * pointSpacing;
    
    const y1 = height - padding - ((rec.glucose_before - minGlucose) / range) * chartHeight;
    ctx.fillStyle = '#60a5fa';
    ctx.beginPath();
    ctx.arc(x, y1, 3, 0, Math.PI * 2);
    ctx.fill();
    
    const y2 = height - padding - ((rec.glucose_after - minGlucose) / range) * chartHeight;
    ctx.fillStyle = '#ef4444';
    ctx.beginPath();
    ctx.arc(x, y2, 3, 0, Math.PI * 2);
    ctx.fill();
  });
}

function drawRiseChart() {
  const canvas = document.getElementById('riseChart');
  if (!canvas) return;
  
  const container = canvas.parentElement;
  canvas.width = container.offsetWidth;
  canvas.height = container.offsetHeight;
  
  const ctx = canvas.getContext('2d');
  const width = canvas.width;
  const height = canvas.height;
  
  const data = allRecords.slice(0, 10).reverse();
  
  if (data.length === 0) {
    ctx.fillStyle = '#cbd5e1';
    ctx.font = '12px sans-serif';
    ctx.textAlign = 'center';
    ctx.fillText('데이터 없음', width / 2, height / 2);
    return;
  }
  
  const padding = 30;
  const chartWidth = width - padding * 2;
  const chartHeight = height - padding * 2;
  const spacing = chartWidth / data.length;
  const barWidth = spacing * 0.6;
  const maxRise = Math.max(...data.map(r => r.glucose_rise), 100);
  
  // 그리드
  ctx.strokeStyle = 'rgba(255,255,255,0.05)';
  ctx.lineWidth = 1;
  for (let i = 0; i <= 4; i++) {
    const y = padding + (chartHeight / 4) * i;
    ctx.beginPath();
    ctx.moveTo(padding, y);
    ctx.lineTo(width - padding, y);
    ctx.stroke();
  }
  
  // 축
  ctx.strokeStyle = 'rgba(255,255,255,0.2)';
  ctx.lineWidth = 1;
  ctx.beginPath();
  ctx.moveTo(padding, height - padding);
  ctx.lineTo(width - padding, height - padding);
  ctx.stroke();
  ctx.beginPath();
  ctx.moveTo(padding, padding);
  ctx.lineTo(padding, height - padding);
  ctx.stroke();
  
  // Y축 라벨
  ctx.fillStyle = '#cbd5e1';
  ctx.font = '10px sans-serif';
  ctx.textAlign = 'right';
  for (let i = 0; i <= 4; i++) {
    const value = (maxRise / 4) * i;
    const y = height - padding - (chartHeight / 4) * i;
    ctx.fillText(Math.round(value), padding - 8, y + 3);
  }
  
  // 목표선 (50)
  const targetY = height - padding - (50 / maxRise) * chartHeight;
  ctx.strokeStyle = '#22c55e';
  ctx.lineWidth = 2;
  ctx.setLineDash([5, 5]);
  ctx.beginPath();
  ctx.moveTo(padding, targetY);
  ctx.lineTo(width - padding, targetY);
  ctx.stroke();
  ctx.setLineDash([]);
  
  // 바 그리기
  data.forEach((rec, i) => {
    const x = padding + i * spacing + spacing / 2 - barWidth / 2;
    const barHeight = (rec.glucose_rise / maxRise) * chartHeight;
    const y = height - padding - barHeight;
    
    let color = '#22c55e';
    if (rec.glucose_rise > 100) color = '#ef4444';
    else if (rec.glucose_rise > 50) color = '#f59e0b';
    
    ctx.fillStyle = color;
    ctx.fillRect(x, y, barWidth, barHeight);
  });
}

