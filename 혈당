  if (!measurement.before || !measurement.after) return;

  const rise = measurement.after - measurement.before;
  const risePercent = Math.round((rise / measurement.before) * 100);
  
  let riskLevel = 'low';
  if (measurement.after >= 180) riskLevel = 'very_high';
  else if (measurement.after >= 140) riskLevel = 'high';
  else if (measurement.after >= 100) riskLevel = 'medium';

  const meal = document.getElementById('mealInput').value || '기록 없음';

  const record = {
    glucose_before: measurement.before,
    glucose_after: measurement.after,
    glucose_rise: rise,
    rise_percentage: risePercent,
    risk_level: riskLevel,
    meal_type: meal,
    timestamp: measurement.timestamp
  };

  allRecords.unshift(record);
  saveRecordsToLocal();
  showToast('💾 기록 저장됨');
  mealStartTime = null;
  notificationShown = false;
  clearInterval(updateElapsedTimeInterval);
  renderHistory();
  updateStats();
  resetMeasure();
}

function schedulePostMealNotification() {
  const fifteenMinutesInMs = 15 * 60 * 1000;
  
  const notificationTimer = setInterval(() => {
    if (!mealStartTime || notificationShown) {
      clearInterval(notificationTimer);
      return;
    }
    
    const now = new Date();
    const elapsedTime = now - mealStartTime;
    
    if (elapsedTime >= fifteenMinutesInMs) {
      notificationShown = true;
      showPostMealNotification();
      clearInterval(notificationTimer);
    }
  }, 10000);
}

