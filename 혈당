}

function dismissPostMealNotif() {
  const elem = document.getElementById('postMealNotification');
  if (elem) {
    elem.style.opacity = '0';
    elem.style.transform = 'translateX(-50%) translateY(-100%)';
    elem.style.transition = 'all 0.3s ease-out';
