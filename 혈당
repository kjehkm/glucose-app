}

function resetMeasure() {
  measurement = { before: null, after: null, timestamp: null };
  document.getElementById('resultPhase').classList.add('hidden');
  document.getElementById('welcomePhase').classList.remove('hidden');
  actionsCompleted = [];
}

// ============ HISTORY & DATA ============

function loadRecords() {
  const stored = localStorage.getItem('glucoseRecords');
  if (stored) {
    try {
      allRecords = JSON.parse(stored).sort((a, b) => new Date(b.timestamp) - new Date(a.timestamp));
    } catch (e) {
      allRecords = [];
    }
  }
  renderHistory();
  updateStats();
}

function saveRecordsToLocal() {
  localStorage.setItem('glucoseRecords', JSON.stringify(allRecords));
}

function renderHistory() {
  const list = document.getElementById('historyList');
  const empty = document.getElementById('emptyHistoryMsg');

  if (!allRecords.length) {
    list.innerHTML = '';
    empty.classList.remove('hidden');
    return;
  }
  empty.classList.add('hidden');

  list.innerHTML = allRecords.map((rec, idx) => {
    const riskInfo = getRiskInfo(rec.risk_level);
    const date = new Date(rec.timestamp);
    const timeStr = `${date.getMonth()+1}/${date.getDate()} ${date.getHours().toString().padStart(2,'0')}:${date.getMinutes().toString().padStart(2,'0')}`;
    
    return `
      <div class="rounded-xl p-4 animate-slide-in" style="background: rgba(255,255,255,0.03); border: 1px solid rgba(251, 191, 36, 0.2);">
        <div class="flex items-start justify-between mb-2">
          <div>
            <div class="flex items-baseline gap-2">
              <p class="text-lg font-black" style="color: #fef3c7;">${rec.glucose_rise}mg/dL</p>
              <p class="text-xs font-bold" style="color: #cbd5e1;">상승</p>
            </div>
          </div>
          <span class="text-xs font-bold px-2 py-1 rounded" style="background: ${riskInfo.color}; color: #fff;">${riskInfo.label}</span>
        </div>
        <div class="grid grid-cols-2 gap-2 mb-2 text-xs">
          <div style="color: #cbd5e1;">
            <p>식전: <span style="color: #60a5fa; font-weight: bold;">${rec.glucose_before}</span></p>
            <p>식후: <span style="color: ${riskInfo.color}; font-weight: bold;">${rec.glucose_after}</span></p>
          </div>
          <div style="color: #cbd5e1;">
            <p>${rec.meal_type}</p>
            <p>${timeStr}</p>
          </div>
        </div>
        <button onclick="requestDelete(${idx})" class="w-full py-1.5 rounded text-xs font-bold" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">삭제</button>
      </div>
    `;
  }).join('');

  lucide.createIcons();
}

function updateStats() {
  if (!allRecords.length) {
    document.getElementById('avgRise').textContent = '-- mg/dL';
    document.getElementById('riseStatus').textContent = '--';
    document.getElementById('achievementRate').textContent = '--%';
    document.getElementById('totalRecords').textContent = '0';
    return;
  }

  const avgRise = Math.round(allRecords.reduce((sum, r) => sum + r.glucose_rise, 0) / allRecords.length);
  document.getElementById('avgRise').textContent = avgRise + ' mg/dL';
  
  const avgRiseStatus = avgRise > 100 ? '⚠️ 높음' : avgRise > 50 ? '🟡 중간' : '✅ 낮음';
  document.getElementById('riseStatus').textContent = avgRiseStatus;

  const achieved = allRecords.filter(r => r.glucose_after < 140).length;
  const rate = Math.round((achieved / allRecords.length) * 100);
  document.getElementById('achievementRate').textContent = rate + '%';
  document.getElementById('achievementBar').style.width = rate + '%';

  const riskCounts = {
    low: allRecords.filter(r => r.risk_level === 'low').length,
    medium: allRecords.filter(r => r.risk_level === 'medium').length,
    high: allRecords.filter(r => r.risk_level === 'high' || r.risk_level === 'very_high').length
  };
  const total = allRecords.length;
  
  if (total > 0) {
    const lowPct = (riskCounts.low / total) * 100;
    const mediumPct = (riskCounts.medium / total) * 100;
    const highPct = (riskCounts.high / total) * 100;

    document.getElementById('riskLowBar').style.width = lowPct + '%';
    document.getElementById('riskLowCount').textContent = riskCounts.low;
    document.getElementById('riskMediumBar').style.width = mediumPct + '%';
    document.getElementById('riskMediumCount').textContent = riskCounts.medium;
    document.getElementById('riskHighBar').style.width = highPct + '%';
    document.getElementById('riskHighCount').textContent = riskCounts.high;
  }

  document.getElementById('totalRecords').textContent = allRecords.length;

  drawGlucoseChart();
  drawRiseChart();
}

function requestDelete(index) {
  deleteTarget = index;
  if (deleteTarget !== null) document.getElementById('deleteConfirm').classList.remove('hidden');
}

function cancelDelete() {
  deleteTarget = null;
  document.getElementById('deleteConfirm').classList.add('hidden');
}

function confirmDelete() {
  if (deleteTarget === null) return;
  allRecords.splice(deleteTarget, 1);
  saveRecordsToLocal();
  document.getElementById('deleteConfirm').classList.add('hidden');
  showToast('✓ 삭제됨');
  deleteTarget = null;
  renderHistory();
  updateStats();
}

