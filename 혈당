          <div style="font-size: 12px; opacity: 0.9; margin-top: 4px;">혈당을 측정하고 분석해보세요</div>
        </div>
        <button onclick="dismissPostMealNotif()" style="margin-left: auto; background: rgba(0,0,0,0.2); border: none; color: #000; padding: 6px 12px; border-radius: 6px; cursor: pointer; font-weight: bold; font-size: 12px;">닫기</button>
